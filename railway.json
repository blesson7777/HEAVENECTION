{
  "$schema": "https://railway.com/railway.schema.json",
  "deploy": {
    "preDeployCommand": "python manage.py migrate --noinput && python manage.py bootstrap_admin_from_env",
    "startCommand": "python manage.py collectstatic --noinput && gunicorn backend.config.wsgi:application --bind 0.0.0.0:$PORT",
    "healthcheckPath": "/health/",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
